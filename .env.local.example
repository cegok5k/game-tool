# Copy this file to .env.local (gitignored) and fill in your keys.
# Vite reads VITE_-prefixed vars and exposes them to the browser bundle.
# The browser PlatformAdapter strips the VITE_ prefix so the app sees the
# canonical names (GOOGLE_GENAI_API_KEY etc).
#
# SECURITY: anything VITE_-prefixed is INLINED into the production build and
# visible to anyone who downloads the JS. Only use this for local-dev keys
# or keys you intentionally want to ship. For an Electron/Tauri build, the
# desktop platform adapter should read from process.env instead.

# Imagen 3 image generation (used by AI Studio)
# Get a key at https://aistudio.google.com/app/apikey
#VITE_GOOGLE_GENAI_API_KEY=

# Veo 3 video generation (Plan 11; not yet wired)
#VITE_GOOGLE_VEO_API_KEY=

# Seedance animation (Plan 12; not yet wired)
#VITE_GOOGLE_SEEDANCE_API_KEY=
